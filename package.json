{
  "name": "new-cli",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:test": "cp .env.test .env && next dev --webpack",
    "dev:prod": "cp .env.production .env && next dev --webpack",
    "build:test": "cp .env.test .env && next build --webpack && npm run clean:txt",
    "build:prod": "cp .env.production .env && next build --webpack && npm run clean:txt",
